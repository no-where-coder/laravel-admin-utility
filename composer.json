{
    "name": "nowhere/laravel-admin-utility",
    "description": "A Laravel admin utility panel with tools like DB viewer, login, impersonation, etc.",
    "type": "library",
    "license": "MIT",
    "authors": [
      {
        "name": "nowhere",
        "email": "contact@nowhere.dev"
      }
    ],
    "require": {
      "php": ">=8.1",
      "illuminate/support": "^10.0|^11.0"
    },
    "autoload": {
      "psr-4": {
        "Nowhere\\AdminUtility\\": "src/"
      }
    },
    "extra": {
      "laravel": {
        "providers": [
          "Nowhere\\AdminUtility\\AdminUtilityServiceProvider"
        ]
      }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
  